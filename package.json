{
  "name": "subgraph-cache",
  "main": "index.ts",
  "scripts": {
    "build": "cd function && pnpm run build",
    "postinstall": "pnpm --dir function --config.engine-strict=false install",
    "test": "cd function && pnpm run test",
    "codegen": "ts-node src/codegen.ts && pnpm run lint",
    "execute": "cd function && pnpm run execute",
    "lint": "prettier --write . && eslint --fix --config ./.eslintrc.js . --ext .jsx,.js,.tsx,.ts",
    "lint:check": "eslint --config ./.eslintrc.js . --ext .jsx,.js,.tsx,.ts --quiet",
    "preinstall": "npx only-allow@1.2.2 pnpm"
